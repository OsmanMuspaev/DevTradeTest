# --------------------------
# DATABASE CONFIGURATION

# Основная строка подключения к базе данных PostgreSQL для AI сервиса
AI_DB_CONNECTION_STRING=postgresql://username:password@host:port/database

# Минимальное количество соединений в пуле
DB_POOL_MIN=1

# Максимальное количество соединений в пуле
DB_POOL_MAX=6


# --------------------------
# LLM PROVIDER SELECTION

# Выбор LLM провайдера. Доступные значения: groq, openai, anthropic, deepseek, together
LLM_PROVIDER=groq

# API ключ для Groq. Если LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here

# --------
# API ключ для OpenAI. Если LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key_here

# Базовый URL для OpenAI API (для прокси или энтерпрайз)
OPENAI_BASE_URL=https://api.openai.com/v1

# Модель для основных задач
OPENAI_MODEL=gpt-4

# Быстрая модель для заголовков и простых задач
OPENAI_FAST_MODEL=gpt-3.5-turbo

# --------
# API ключ для Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Модель Claude для основных задач. Доступные: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
CLAUDE_MODEL=claude-3-sonnet-20240229

# Быстрая модель Claude для простых задач
CLAUDE_FAST_MODEL=claude-3-haiku-20240307

# --------
# API ключ для DeepSeek
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# --------
# API ключ для Together AI
TOGETHER_API_KEY=your_together_api_key_here


# --------------------------
# AI MODEL DEFAULT SETTINGS

# Основная модель по умолчанию (для ответов в чате)
# Для Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# Для OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Для Anthropic: claude-3-sonnet-20240229, claude-3-haiku-20240307
DEFAULT_MODEL=llama-3.3-70b-versatile

# Быстрая модель (для заголовков, кратких ответов)
DEFAULT_FAST_MODEL=llama-3.1-8b-instant

# Температура генерации (креативность)
# Диапазон: 0.0 (детерминировано) - 1.0 (максимально креативно)
DEFAULT_TEMPERATURE=0.7

# Максимальное количество токенов в ответе
DEFAULT_MAX_TOKENS=2000


# --------------------------
# DOCKER COMPOSE SETTINGS

# PostgreSQL пользователь для AI базы данных
AI_POSTGRES_USER=postgres

# PostgreSQL пароль для AI базы данных
AI_POSTGRES_PASSWORD=postgres

# Название AI базы данных
AI_POSTGRES_DB=ai_db

# PostgreSQL пользователь для основной базы данных
POSTGRES_USER=postgres

# PostgreSQL пароль для основной базы данных
POSTGRES_PASSWORD=postgres

# Название основной базы данных
POSTGRES_DB=devtrade